		"modmenu": [
			"com.github.noamm9.packdisabler.ModMenuIntegration"
		]
	},
	"depends": {
		"fabricloader": ">=${fabric_loader_version}",
		"minecraft": "${mcdep}",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}